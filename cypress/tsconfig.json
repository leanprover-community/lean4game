{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "nodenext",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": "./",
    "strict": true,
    "target": "ES2022",
  },
  "include": ["**/*.ts", "**/*.tsx", "../cypress.config.cjs"],
  "exclude": ["dist"]
}
